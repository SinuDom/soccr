{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Content Schema",
  "type": "object",
  "required": ["settings", "users"],
  "properties": {
    "$schema": { "type": "string" },
    "settings": {
      "type": "object",
      "required": [
        "sessionTargetMinutes",
        "pointsPerExtraMinute",
        "freezeCostPoints",
        "maxFreezesHeld",
        "recycleWhenLibraryExhausted"
      ],
      "properties": {
        "sessionTargetMinutes": { "type": "integer", "minimum": 1 },
        "pointsPerExtraMinute": { "type": "integer", "minimum": 0 },
        "freezeCostPoints": { "type": "integer", "minimum": 0 },
        "maxFreezesHeld": { "type": "integer", "minimum": 0 },
        "recycleWhenLibraryExhausted": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "videos"],
        "properties": {
          "name": { "type": "string" },
          "videos": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["url", "title"],
              "properties": {
                "url": { "type": "string", "format": "uri" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "timerTitles": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Individual titles for each drill timer/set. The nth string labels the nth timer."
                },
                "timer": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "How long to perform one drill, in seconds."
                },
                "repetition": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "How many identical drill timers to run, shown next to each other."
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
